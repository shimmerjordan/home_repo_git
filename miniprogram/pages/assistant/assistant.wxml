<view class="chat">
  <view wx:for="{{log}}" wx:key="index" class="msg {{item.role}}">
    <view class="bubble {{item.role}}">
      <text>{{item.text}}</text>
      <!-- 候选/结果物品 -->
      <view wx:if="{{item.candidates.length}}" class="cands">
        <view wx:for="{{item.candidates}}" wx:for-item="c" wx:key="item_id"
          class="cand" data-id="{{c.item_id}}" bindtap="goItem">
          {{c.item_name}}<text wx:if="{{c.location_path}}" class="muted"> · {{c.location_path}}</text>
        </view>
      </view>
      <!-- 低置信度待确认 -->
      <view wx:if="{{item.pending}}" class="row" style="gap:16rpx;margin-top:12rpx">
        <button class="btn btn-primary" size="mini" data-idx="{{index}}" bindtap="confirm">确认</button>
        <button class="btn btn-secondary" size="mini" data-idx="{{index}}" bindtap="cancel">取消</button>
      </view>
    </view>
  </view>
  <view wx:if="{{log.length===0}}" class="muted" style="text-align:center;margin-top:80rpx">
    说点什么吧，例如「充电宝在哪」「我借走了螺丝刀」「在卧室放了两把雨伞」。
  </view>
</view>

<view class="composer">
  <input class="input" placeholder="输入指令或点麦克风说话" value="{{text}}" bindinput="onInput" confirm-type="send" bindconfirm="send" />
  <button wx:if="{{voiceReady}}" class="mic {{recording?'rec':''}}" bindtouchstart="startVoice" bindtouchend="stopVoice">🎙</button>
  <button class="btn btn-primary" loading="{{busy}}" bindtap="send">发送</button>
  <view class="gear" bindtap="goSettings">⚙</view>
</view>
