<view class="card gap">
  <view style="font-weight:600">新增位置</view>
  <input class="input" placeholder="名称, 如 卧室 / 工具箱" value="{{newName}}" bindinput="onName" />
  <view class="row" style="gap:16rpx">
    <picker style="flex:1" mode="selector" range="{{kinds}}" range-key="label" value="{{kindIndex}}" bindchange="onKind">
      <view class="input">类型：{{kinds[kindIndex].label}}</view>
    </picker>
    <picker style="flex:1" mode="selector" range="{{parentOptions}}" range-key="label" value="{{parentIndex}}" bindchange="onParent">
      <view class="input">上级：{{parentOptions[parentIndex].label}}</view>
    </picker>
  </view>
  <view wx:if="{{err}}" class="err">{{err}}</view>
  <button class="btn btn-primary" bindtap="add">添加</button>
</view>

<view class="card">
  <view style="font-weight:600;margin-bottom:8rpx">全部位置</view>
  <view wx:if="{{locs.length === 0}}" class="muted">暂无位置。</view>
  <view wx:for="{{locs}}" wx:key="id" class="row between" style="padding:14rpx 0;border-top:1rpx solid #f1f5f9">
    <view>{{item.label}}</view>
    <view class="row" style="gap:20rpx">
      <text style="color:#0ea5e9" data-id="{{item.id}}" bindtap="rename">改名</text>
      <text style="color:#b91c1c" data-id="{{item.id}}" bindtap="del">删除</text>
    </view>
  </view>
</view>
